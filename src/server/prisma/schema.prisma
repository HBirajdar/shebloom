// ──────────────────────────────────────────────────────
// VedaClue Database Schema (Prisma + PostgreSQL)
// ──────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────

enum Role {
  USER
  DOCTOR
  ADMIN
}

enum AuthProvider {
  EMAIL
  PHONE
  GOOGLE
  APPLE
}

enum CyclePhase {
  MENSTRUAL
  FOLLICULAR
  OVULATION
  LUTEAL
}

enum MoodLevel {
  GREAT
  GOOD
  OKAY
  LOW
  BAD
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  REJECTED
  NO_SHOW
  CANCELLED
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum Language {
  ENGLISH
  HINDI
  TAMIL
  KANNADA
  TELUGU
  MARATHI
  BENGALI
  GUJARATI
}

enum DoshaType {
  VATA
  PITTA
  KAPHA
  VATA_PITTA
  PITTA_KAPHA
  VATA_KAPHA
  TRIDOSHIC
}

enum AssessmentType {
  SELF_QUICK     // 3-question onboarding quiz
  SELF_FULL      // 20+ question full assessment
  DOCTOR_CLINICAL // Doctor's clinical Prakriti assessment
  ADMIN_OVERRIDE  // Admin verification/override
}

// ─── USER ───────────────────────────────────────────

model User {
  id           String       @id @default(cuid())
  email        String?      @unique
  phone        String?      @unique
  passwordHash String?
  fullName     String
  avatarUrl    String?
  photoUrl     String?
  dateOfBirth  DateTime?
  role         Role         @default(USER)
  authProvider AuthProvider @default(EMAIL)
  isVerified   Boolean      @default(false)
  isActive     Boolean      @default(true)
  language     Language     @default(ENGLISH)
  timezone     String       @default("Asia/Kolkata")
  fcmToken     String? // Firebase Cloud Messaging
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  profile          UserProfile?
  cycles           Cycle[]
  moodLogs         MoodLog[]
  symptomLogs      SymptomLog[]
  bbtLogs          BBTLog[]
  cervicalMucusLogs CervicalMucusLog[]
  fertilityDailyLogs FertilityDailyLog[]
  pregnancies      Pregnancy[]
  appointments     Appointment[]
  articleBookmarks ArticleBookmark[]
  articleLikes     ArticleLike[]
  articleComments  ArticleComment[]
  waterLogs        WaterLog[]
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  prescriptions    Prescription[]
  orders           Order[]
  doctorProfile    Doctor?          @relation("DoctorUser")
  doctorReviews    DoctorReview[]
  productReviews   ProductReview[]
  wishlistItems    WishlistItem[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model UserProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  cycleLength         Int       @default(28)
  periodLength        Int       @default(5)
  lastPeriodDate      DateTime?
  primaryGoal         String? // track_periods, pregnancy, wellness, fertility
  interests           String[] // Array of interest tags
  height              Float? // cm
  weight              Float? // kg
  bloodGroup          String?
  medicalConditions   String[]
  allergies           String[]
  isPregnant          Boolean   @default(false)
  pregnancyWeek       Int?
  contraceptiveMethod String?
  dosha               String?   // Ayurvedic constitution: Vata, Pitta, Kapha
  doshaType           DoshaType? // Structured dosha (supports dual doshas)
  vataScore           Float?    // 0-100 percentage from assessment
  pittaScore          Float?    // 0-100 percentage from assessment
  kaphaScore          Float?    // 0-100 percentage from assessment
  doshaConfidence     Float?    // 0-100 assessment confidence
  doshaVerified       Boolean   @default(false) // Verified by doctor/admin
  doshaVerifiedBy     String?   // Doctor/Admin userId who verified
  doshaVerifiedAt     DateTime?
  locationLatitude    Float?
  locationLongitude   Float?
  city                String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  doshaAssessments  DoshaAssessment[]

  @@map("user_profiles")
}

// ─── DOSHA ASSESSMENT ──────────────────────────────
// Stores each dosha assessment (self-quiz, doctor clinical, admin override)
// Multiple assessments per user — only one active at a time

model DoshaAssessment {
  id               String         @id @default(cuid())
  userId           String
  profileId        String
  assessmentType   AssessmentType @default(SELF_QUICK)
  answers          Json           // Array of {questionId, selectedOptionIndex, vataScore, pittaScore, kaphaScore}
  primaryDosha     DoshaType
  secondaryDosha   DoshaType?
  vataScore        Float          // 0-100 percentage
  pittaScore       Float          // 0-100 percentage
  kaphaScore       Float          // 0-100 percentage
  confidence       Float          @default(30) // 0-100, higher for doctor assessments
  isActive         Boolean        @default(true)
  assessedBy       String?        // Doctor/Admin userId who performed this
  assessedByName   String?        // Name of assessor for display
  verificationNotes String?       // Doctor/Admin notes
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  profile UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([profileId])
  @@map("dosha_assessments")
}

// ─── DOSHA QUESTIONS ───────────────────────────────
// Admin-manageable question bank for Prakriti assessment

model DoshaQuestion {
  id               String   @id @default(cuid())
  questionText     String
  questionCategory String   // body_type, digestion, sleep, stress, skin, menstrual, emotional, energy, appetite, climate
  options          Json     // Array of {label, vataScore, pittaScore, kaphaScore}
  weight           Float    @default(1.0) // Diagnostic weight
  orderIndex       Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive, orderIndex])
  @@map("dosha_questions")
}

// ─── USER WEATHER / LOCATION ──────────────────────
// Cached weather data per user location for Ayurvedic seasonal adjustments

model UserWeatherCache {
  id               String    @id @default(cuid())
  userId           String    @unique
  latitude         Float
  longitude        Float
  city             String?
  country          String?
  temperature      Float?    // Celsius
  humidity         Float?    // Percentage
  weatherCondition String?   // clear, clouds, rain, snow, etc.
  windSpeed        Float?    // m/s
  description      String?   // "light rain", "clear sky"
  lastFetchedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("user_weather_cache")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// ─── CYCLE TRACKING ─────────────────────────────────

model Cycle {
  id            String    @id @default(cuid())
  userId        String
  startDate     DateTime
  endDate       DateTime?
  cycleLength   Int?
  periodLength  Int?
  ovulationDate DateTime?
  fertileStart  DateTime?
  fertileEnd    DateTime?
  isPredicted   Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@map("cycles")
}

model MoodLog {
  id        String    @id @default(cuid())
  userId    String
  mood      MoodLevel
  notes     String?
  logDate   DateTime  @default(now())
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, logDate])
  @@map("mood_logs")
}

model SymptomLog {
  id        String   @id @default(cuid())
  userId    String
  symptoms  String[] // Array of symptom names
  severity  Int?     @default(5) // 1-10 scale
  notes     String?
  logDate   DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, logDate])
  @@map("symptom_logs")
}

// ─── ADVANCED FERTILITY TRACKING ────────────────────
// Based on: Wilcox et al. (1995 BMJ), Fehring et al. (2006),
// Bull et al. (2019 npj Digital Medicine), ACOG guidelines

model BBTLog {
  id          String   @id @default(cuid())
  userId      String
  temperature Float    // Celsius, e.g. 36.45
  time        String?  // "06:30" — time of measurement
  method      String   @default("oral") // oral, vaginal, tympanic
  notes       String?
  logDate     DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, logDate])
  @@index([userId, logDate])
  @@map("bbt_logs")
}

model CervicalMucusLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // dry, sticky, creamy, watery, eggWhite, spotting
  amount    String?  // none, light, moderate, heavy
  notes     String?
  logDate   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, logDate])
  @@index([userId, logDate])
  @@map("cervical_mucus_logs")
}

model FertilityDailyLog {
  id               String   @id @default(cuid())
  userId           String
  logDate          DateTime
  bbt              Float?   // BBT reading
  cervicalMucus    String?  // CM type
  cervicalPosition String?  // low-firm-closed, mid-medium-partial, high-soft-open
  lhTestResult     String?  // negative, faint, positive, peak
  intercourse      Boolean  @default(false)
  fertilityScore   Float?   // 0-100 computed fertility probability
  phase            String?  // menstrual, follicular, ovulation, luteal
  notes            String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, logDate])
  @@index([userId, logDate])
  @@map("fertility_daily_logs")
}

model WaterLog {
  id            String   @id @default(cuid())
  userId        String
  glasses       Int      @default(0)
  targetGlasses Int      @default(8)
  logDate       DateTime @default(now())
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, logDate])
  @@map("water_logs")
}

// ─── PREGNANCY ──────────────────────────────────────

model Pregnancy {
  id             String    @id @default(cuid())
  userId         String
  dueDate        DateTime
  conceptionDate DateTime?
  currentWeek    Int       @default(1)
  isActive       Boolean   @default(true)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistItems PregnancyChecklist[]

  @@index([userId])
  @@map("pregnancies")
}

model PregnancyChecklist {
  id          String    @id @default(cuid())
  pregnancyId String
  week        Int
  title       String
  description String?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  pregnancy Pregnancy @relation(fields: [pregnancyId], references: [id], onDelete: Cascade)

  @@index([pregnancyId, week])
  @@map("pregnancy_checklists")
}

// ─── DOCTORS ────────────────────────────────────────

model Doctor {
  id              String     @id @default(cuid())
  userId          String?    @unique
  user            User?      @relation("DoctorUser", fields: [userId], references: [id], onDelete: SetNull)
  fullName        String
  specialization  String
  qualifications  String[]
  experienceYears Int
  hospitalName    String?
  hospitalId      String?
  consultationFee Float
  commissionRate  Float?     // Per-doctor override (null = use platform default). Like Practo — top docs get lower commission.
  rating          Float      @default(0)
  totalReviews    Int        @default(0)
  languages       Language[]
  tags            String[]
  bio             String?
  avatarUrl       String?
  photoUrl        String?
  clinicPhotos    String[]   @default([])
  introVideoUrl   String?
  isAvailable     Boolean    @default(true)
  isVerified      Boolean    @default(false)
  isPublished     Boolean    @default(false)
  isChief         Boolean    @default(false)
  isPromoted      Boolean    @default(false)
  approvedBy      String?
  approvedAt      DateTime?
  publishedAt     DateTime?
  status          String     @default("pending")
  location        String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  hospital       Hospital?      @relation(fields: [hospitalId], references: [id])
  appointments   Appointment[]
  articles       Article[]
  reviews        DoctorReview[]
  availableSlots DoctorSlot[]
  prescriptions  Prescription[]
  payouts        DoctorPayout[]

  @@index([specialization])
  @@index([rating])
  @@index([consultationFee])
  @@map("doctors")
}

model DoctorSlot {
  id        String  @id @default(cuid())
  doctorId  String
  dayOfWeek Int // 0=Sun, 6=Sat
  startTime String // "09:00"
  endTime   String // "17:00"
  isActive  Boolean @default(true)

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_slots")
}

model DoctorReview {
  id        String   @id @default(cuid())
  doctorId  String
  userId    String
  rating    Float
  comment   String?
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@map("doctor_reviews")
}

model Appointment {
  id                 String            @id @default(cuid())
  userId             String
  doctorId           String? // Changed: was String (required)
  doctorName         String? // Added: stores name for custom/admin doctors
  scheduledAt        DateTime
  duration           Int               @default(30)
  status             AppointmentStatus @default(PENDING)
  type               String            @default("consultation")
  notes              String?
  meetingLink        String?
  paymentId          String?
  amountPaid         Float?     // Final amount paid after all discounts
  originalFee        Float?     // Doctor's original consultation fee
  couponCode         String?    // Applied coupon code
  couponDiscount     Float?     // Discount from coupon
  platformFee        Float?     // Platform convenience fee
  cancellationReason String?
  rejectionReason    String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor       Doctor?       @relation(fields: [doctorId], references: [id], onDelete: SetNull) // Changed: was non-optional
  prescription Prescription?

  @@index([userId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@map("appointments")
}

// ─── HOSPITALS ──────────────────────────────────────

model Hospital {
  id            String   @id @default(cuid())
  name          String
  address       String
  city          String
  state         String
  pincode       String
  latitude      Float?
  longitude     Float?
  phone         String?
  email         String?
  website       String?
  rating        Float    @default(0)
  totalBeds     Int?
  hasEmergency  Boolean  @default(false)
  category      String? // budget, mid_range, premium
  accreditation String[] // NABH, JCI, etc.
  specialties   String[]
  imageUrls     String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  doctors Doctor[]
  prices  HospitalPrice[]

  @@index([city])
  @@index([rating])
  @@map("hospitals")
}

model HospitalPrice {
  id          String   @id @default(cuid())
  hospitalId  String
  serviceName String // "Consultation", "Normal Delivery", "C-Section", "Health Check-up"
  minPrice    Float
  maxPrice    Float?
  currency    String   @default("INR")
  lastUpdated DateTime @default(now())

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@map("hospital_prices")
}

// ─── ARTICLES ───────────────────────────────────────

model Article {
  id              String        @id @default(cuid())
  doctorId        String?
  title           String
  slug            String        @unique
  content         String
  excerpt         String?
  category        String // periods, pregnancy, pcod, wellness, nutrition, mental_health
  tags            String[]
  coverImageUrl   String?
  readTimeMinutes Int           @default(5)
  emoji           String        @default("📝")
  targetAudience  String[]      @default([])
  status          ArticleStatus @default(DRAFT)
  viewCount       Int           @default(0)
  likeCount       Int           @default(0)
  isFeatured      Boolean       @default(false)
  publishedAt     DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  authorName      String        @default("VedaClue Team")

  // ─── Credibility & Audit fields ───
  references      String[]      @default([]) // Medical references (journal articles, textbooks, etc.)
  sources         String[]      @default([]) // Source URLs or citations
  disclaimer      String?       // Custom disclaimer for this article
  reviewNotes     String?       // Internal notes from admin review
  medicalReviewedBy String?     // Name/ID of medical reviewer
  medicalReviewedAt DateTime?   // When medical review was done
  evidenceLevel   String?       // e.g. "peer-reviewed", "clinical-study", "traditional-knowledge", "expert-opinion"
  authorQualification String?   // Doctor's qualification shown on article (e.g. "BAMS, MD Ayurveda")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  doctor    Doctor?           @relation(fields: [doctorId], references: [id])
  bookmarks ArticleBookmark[]
  likes     ArticleLike[]
  comments  ArticleComment[]

  @@index([category])
  @@index([status])
  @@index([slug])
  @@map("articles")
}

model ArticleBookmark {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("article_bookmarks")
}

model ArticleLike {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  type      String   @default("LIKE") // LIKE or DISLIKE
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("article_likes")
}

model ArticleComment {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  content   String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("article_comments")
}

// ─── NOTIFICATIONS ──────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String // period_reminder, appointment, article, wellness_tip
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─── WELLNESS ───────────────────────────────────────

model WellnessActivity {
  id              String       @id @default(cuid())
  title           String
  description     String?
  category        String // meditation, yoga, stress_management, breathing
  durationMinutes Int
  difficulty      String       @default("beginner") // beginner, intermediate, advanced
  cyclePhases     CyclePhase[] // recommended during these phases
  imageUrl        String?
  audioUrl        String?
  videoUrl        String?
  instructions    Json?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([category])
  @@map("wellness_activities")
}

// ─── OTP STORE ──────────────────────────────────────

model OtpStore {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@map("otp_store")
}

// ─── AUDIT LOG ──────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // login, logout, data_access, data_update, data_delete
  resource   String // user, cycle, appointment, etc.
  resourceId String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── PRODUCTS (Ayurveda Shop) ──────────────────────

model Product {
  id             String    @id @default(cuid())
  name           String
  category       String
  price          Int
  discountPrice  Int?
  description    String
  ingredients    String[]
  benefits       String[]
  howToUse       String
  size           String
  emoji          String    @default("🌿")
  rating         Float     @default(5.0)
  reviews        Int       @default(0)
  inStock        Boolean   @default(true)
  isPublished    Boolean   @default(false)
  isFeatured     Boolean   @default(false)
  targetAudience String[]
  tags           String[]
  imageUrl       String?
  galleryImages  String[]  @default([])
  videoUrl       String?
  ownerEmail     String?
  ownerPhone     String?
  status         String    @default("draft")
  publishedAt    DateTime?
  approvedBy     String?
  approvedAt     DateTime?
  stock          Int       @default(0)
  unit           String    @default("piece")
  // Ayurveda-specific (like Forest Essentials / Kama Ayurveda)
  doshaTypes     String[]  @default([])   // ["VATA","PITTA","KAPHA"] — which doshas this product suits
  bestFor        String[]  @default([])   // ["dry_skin","hair_fall","stress"] — searchable benefit tags
  skinType       String?                   // "oily", "dry", "combination", "sensitive", "normal"
  preparationMethod String?                // "cold-pressed", "steam-distilled", "hand-ground"
  shelfLife      String?                   // "6 months", "1 year"
  certifications String[]  @default([])   // ["organic", "cruelty-free", "lab-tested", "GMP"]
  weight         String?                   // "100ml", "200g"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orderItems      OrderItem[]
  productReviews  ProductReview[]
  wishlistItems   WishlistItem[]

  @@index([category])
  @@index([isPublished])
  @@index([rating])
  @@map("products")
}

// ─── PRODUCT REVIEWS ──────────────────────────────────
// Like Amazon/Flipkart verified purchase reviews with star ratings

model ProductReview {
  id              String   @id @default(cuid())
  productId       String
  userId          String
  rating          Float                    // 1-5 stars
  title           String?                  // Review headline
  comment         String?                  // Review body
  isVerifiedPurchase Boolean @default(false) // User actually bought this product
  helpfulCount    Int      @default(0)     // Upvotes
  images          String[] @default([])    // Review photos
  adminReply      String?                  // Seller/admin response
  isApproved      Boolean  @default(true)  // Moderation flag
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])            // One review per product per user
  @@index([productId, isApproved])
  @@index([userId])
  @@map("product_reviews")
}

// ─── WISHLIST ─────────────────────────────────────────
// Server-persisted wishlist (syncs across devices, unlike localStorage)

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}

// ─── CALLBACK REQUESTS ─────────────────────────────

model CallbackRequest {
  id          String   @id @default(cuid())
  userId      String?
  productId   String?
  userName    String
  userPhone   String
  userEmail   String?
  productName String
  ownerEmail  String?
  ownerPhone  String?
  message     String?
  status      String   @default("PENDING") // PENDING | CALLED | RESOLVED
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([productId])
  @@map("callback_requests")
}

// ─── PRESCRIPTIONS ──────────────────────────────────

model Prescription {
  id            String    @id @default(cuid())
  appointmentId String    @unique
  doctorId      String
  userId        String
  diagnosis     String
  medicines     Json // [{name, dosage, frequency, duration}]
  instructions  String?
  followUpDate  DateTime?
  pdfUrl        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  doctor      Doctor      @relation(fields: [doctorId], references: [id])
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([doctorId])
  @@map("prescriptions")
}

// ─── ORDERS (Razorpay + COD) ────────────────────────

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  userId            String
  items             OrderItem[]
  subtotal          Float
  discount          Float       @default(0)
  couponCode        String?                           // Applied coupon code
  couponDiscount    Float       @default(0)           // Discount from coupon
  platformFee       Float       @default(0)           // Platform/convenience fee
  deliveryCharge    Float       @default(0)
  gstAmount         Float       @default(0)           // GST amount
  totalAmount       Float
  paymentMethod     String      @default("razorpay")
  paymentStatus     String      @default("PENDING")
  paymentId         String?
  razorpayOrderId   String?
  razorpaySignature String?
  orderStatus       String      @default("PENDING")
  deliveryAddress   Json
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orderStatus])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  price       Float
  totalPrice  Float
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── DOCTOR PAYOUTS & SETTLEMENTS ──────────────────
// Revenue split model: Platform keeps a commission %, rest goes to doctor.
// Like Practo/Clue/Zocdoc: admin settles payouts periodically.

model DoctorPayout {
  id              String        @id @default(cuid())
  doctorId        String
  periodStart     DateTime      // Settlement period start
  periodEnd       DateTime      // Settlement period end
  totalEarnings   Float         // Gross amount from completed appointments
  platformFee     Float         // Platform commission amount
  netPayout       Float         // Amount to be paid to doctor
  commissionRate  Float         @default(20) // Platform commission % (e.g. 20 = 20%)
  appointmentCount Int          // Number of appointments in this payout
  status          PayoutStatus  @default(PENDING)
  paymentMethod   String?       // UPI / Bank Transfer / Razorpay etc.
  transactionId   String?       // UTR / transaction reference
  paidAt          DateTime?     // When payment was made
  adminNotes      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  doctor          Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([status])
  @@index([createdAt])
  @@map("doctor_payouts")
}

enum PayoutStatus {
  PENDING       // Settlement generated, not yet paid
  PROCESSING    // Payment initiated
  PAID          // Successfully paid to doctor
  FAILED        // Payment failed
  ON_HOLD       // Held by admin (dispute etc.)
}

// ─── PLATFORM CONFIGURATION ──────────────────────────
// Global settings for fees, commissions, delivery etc.
// Like Practo/Apollo/Amazon — centralized config, admin editable.

model PlatformConfig {
  id                      String   @id @default("default")
  // Doctor consultation commission
  defaultDoctorCommission Float    @default(20)      // % platform keeps from doctor appointments
  // Product sales commission
  defaultProductCommission Float   @default(15)      // % platform keeps from product sales
  // Delivery
  deliveryCharge          Float    @default(49)
  freeDeliveryAbove       Float    @default(499)
  // Tax
  gstRate                 Float    @default(18)       // GST % (India)
  includeGstInPrice       Boolean  @default(true)     // If true, prices are GST-inclusive
  // Convenience / platform fee
  platformFeeFlat         Float    @default(0)        // Flat fee per order (like Zomato's platform fee)
  platformFeePercent      Float    @default(2)        // % fee per order (like Zomato 2-5%)
  // Cancellation
  cancellationWindowHours Int      @default(24)       // Free cancellation within N hours of booking
  cancellationPenalty     Float    @default(0)        // % deducted on late cancellation
  // COD
  codEnabled              Boolean  @default(true)
  codExtraCharge          Float    @default(0)        // Extra charge for COD orders
  // Minimum order
  minOrderAmount          Float    @default(0)
  // Refund
  refundProcessingDays    Int      @default(7)
  updatedAt               DateTime @updatedAt

  @@map("platform_config")
}

// ─── COUPONS & DISCOUNTS ─────────────────────────────
// Like Amazon/Flipkart/Zomato — promo codes for both consultations and products.

model Coupon {
  id                String       @id @default(cuid())
  code              String       @unique              // e.g. "FIRST50", "DIWALI20"
  description       String?
  // Discount config
  discountType      DiscountType @default(PERCENTAGE) // PERCENTAGE or FLAT
  discountValue     Float                             // 20 means 20% or ₹20
  maxDiscountAmount Float?                            // Cap: max ₹200 off (for % discounts)
  minOrderAmount    Float        @default(0)          // Min cart/fee to apply coupon
  // Scope
  applicableTo      CouponScope  @default(ALL)        // ALL, CONSULTATION, PRODUCTS
  // Targeting (like Zomato/Amazon — specific doctor/product/category)
  specificDoctorIds String[]     @default([])          // Empty = all doctors
  specificProductIds String[]    @default([])          // Empty = all products
  specificCategories String[]    @default([])          // Empty = all categories
  // Limits
  maxUses           Int?                              // Total uses allowed (null = unlimited)
  maxUsesPerUser    Int          @default(1)           // Uses per user
  currentUses       Int          @default(0)           // Track total redemptions
  // Validity
  validFrom         DateTime     @default(now())
  validUntil        DateTime?                          // null = no expiry
  isActive          Boolean      @default(true)
  // First-time user only (like PharmEasy, Zepto first-order coupons)
  firstOrderOnly    Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  redemptions       CouponRedemption[]

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  userId     String
  orderId    String?  // For product orders
  appointmentId String? // For consultation bookings
  discount   Float    // Actual discount applied
  createdAt  DateTime @default(now())

  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemptions")
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum CouponScope {
  ALL
  CONSULTATION
  PRODUCTS
}

// ─── PRODUCT PAYOUTS (seller/vendor settlement) ──────
// For future marketplace: if products are sold by different sellers,
// track their earnings separately. Currently VedaClue owns products
// but this supports vendor onboarding (like Amazon/Flipkart seller model).

model ProductPayout {
  id              String        @id @default(cuid())
  periodStart     DateTime
  periodEnd       DateTime
  totalSales      Float         // Gross sales in period
  totalOrders     Int           // Number of orders
  platformFee     Float         // Platform commission amount
  netPayout       Float         // Amount after commission
  commissionRate  Float         @default(15) // % platform keeps
  gstCollected    Float         @default(0)  // GST collected
  deliveryCharges Float         @default(0)  // Total delivery charges collected
  status          PayoutStatus  @default(PENDING)
  paymentMethod   String?
  transactionId   String?
  paidAt          DateTime?
  adminNotes      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("product_payouts")
}

// ─── PAYMENT AUDIT LOG ──────────────────────────────
// Immutable ledger of every payment event — protects during disputes,
// chargebacks, refund claims, and regulatory audits. Never deleted.

model PaymentAuditLog {
  id              String   @id @default(cuid())
  // Who & what
  userId          String
  eventType       String                // ORDER_CREATED, ORDER_PAID, ORDER_COD, APPOINTMENT_PAID, REFUND, WEBHOOK_CAPTURED
  // Payment identifiers
  orderId         String?               // Internal order ID (for product orders)
  appointmentId   String?               // Internal appointment ID (for consultations)
  orderNumber     String?               // Human-readable order number (VC-xxxx)
  razorpayOrderId String?               // Razorpay order ID
  razorpayPaymentId String?             // Razorpay payment ID (pay_xxxx)
  // Financial snapshot (immutable at time of event)
  subtotal        Float    @default(0)  // Original amount before any discounts/fees
  couponCode      String?               // Coupon applied (if any)
  couponDiscount  Float    @default(0)  // Discount from coupon
  platformFee     Float    @default(0)  // Platform/convenience fee charged
  deliveryCharge  Float    @default(0)  // Delivery fee (products only)
  codCharge       Float    @default(0)  // COD extra charge (if applicable)
  gstAmount       Float    @default(0)  // GST charged
  totalAmount     Float    @default(0)  // Final amount charged/collected
  // Context
  paymentMethod   String?               // razorpay, COD, free
  currency        String   @default("INR")
  doctorId        String?               // Doctor (for appointment payments)
  commissionRate  Float?                // Platform commission % at time of payment
  // Metadata
  ipAddress       String?               // Client IP for fraud detection
  userAgent       String?               // Browser/device info
  metadata        Json?                 // Any extra context (Razorpay response, notes, etc.)
  // Timestamps
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([orderId])
  @@index([appointmentId])
  @@index([razorpayPaymentId])
  @@index([createdAt])
  @@map("payment_audit_logs")
}
